# ============================================================
# ToolSense Benchmarks — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# LiteLLM Proxy (for all LLM generation and validation calls)
# ------------------------------------------------------------
# Base URL of your LiteLLM proxy server.
# Leave empty to call providers directly (e.g. OpenAI, Anthropic).
LITELLM_BASE_URL=http://localhost:4000

# API key for the LiteLLM proxy (leave empty if not required).
LITELLM_API_KEY=

# Default model name passed to the proxy (can be overridden per-script via --model).
# Required — no hardcoded fallback. Use the model alias configured in your LiteLLM proxy
# config, or a standard LiteLLM model string: https://docs.litellm.ai/docs/providers
DEFAULT_MODEL=

# ------------------------------------------------------------
# Embeddings  (realistic_benchmark only — hard-negative retrieval)
# ------------------------------------------------------------
# OpenAI API key used by chromadb's OpenAIEmbeddingFunction.
# If your LiteLLM proxy exposes an OpenAI-compatible /embeddings endpoint,
# set OPENAI_API_BASE to the proxy URL instead and use any key here.
OPENAI_API_KEY=sk-...

# Optional: redirect OpenAI API calls (including embeddings) through a proxy.
# Uncomment and set to your proxy URL if you want all calls to go through one endpoint.
# OPENAI_API_BASE=http://localhost:4000

# Embedding model name (default: text-embedding-3-large).
# EMBEDDING_MODEL=text-embedding-3-large

# ------------------------------------------------------------
# Provider keys (only needed if NOT using a proxy)
# ------------------------------------------------------------
# Uncomment whichever provider you use directly:

# ANTHROPIC_API_KEY=sk-ant-...
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2024-02-01
# AWS_ACCESS_KEY_ID=...        # for Bedrock
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1